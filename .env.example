# Database (REQUIRED)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Authentication (REQUIRED)
# Generate JWT secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
ADMIN_EMAIL=admin@example.com
# Generate bcrypt hash: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
# IMPORTANT: Escape $ as \$ in .env files
ADMIN_PASSWORD_HASH=
ADMIN_ACCESS_CODE=

# Rate Limiting (optional - works without these, just won't rate limit)
# Get free Redis at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site URL (for CSRF validation and sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
