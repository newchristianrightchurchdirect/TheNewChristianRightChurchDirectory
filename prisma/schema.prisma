generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Church {
  id               Int      @id @default(autoincrement())
  name             String
  denomination     String?
  address          String
  city             String
  state            String
  zip              String?
  latitude         Float?
  longitude        Float?
  website          String?
  phone            String?
  email            String?
  zionistStance    String   @default("unknown") // "yes", "no", "anti", "unknown"
  abolitionStance  String   @default("unknown") // "pro_abolition", "anti", "incrementalist", "unknown"
  theologicalNotes String?
  description      String?
  approved         Boolean  @default(false)
  upvotes          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Report {
  id        Int      @id @default(autoincrement())
  churchId  Int
  reason    String
  details   String?
  createdAt DateTime @default(now())
}
