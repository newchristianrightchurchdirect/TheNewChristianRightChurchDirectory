generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Church {
  id               Int      @id @default(autoincrement())
  name             String
  denomination     String?
  address          String
  city             String
  state            String
  zip              String?
  latitude         Float?
  longitude        Float?
  website          String?
  phone            String?
  zionistStance    String   @default("unknown") // "yes", "no", "unknown"
  theologicalNotes String?
  description      String?
  approved         Boolean  @default(false)
  upvotes          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Report {
  id        Int      @id @default(autoincrement())
  churchId  Int
  reason    String
  details   String?
  createdAt DateTime @default(now())
}
