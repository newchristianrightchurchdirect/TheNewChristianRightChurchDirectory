generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Church {
  id           Int      @id @default(autoincrement())
  name         String
  denomination String?
  address      String
  city         String
  state        String
  zip          String?
  latitude     Float?
  longitude    Float?
  website      String?
  phone        String?
  proZionist   Boolean  @default(false)
  description  String?
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
